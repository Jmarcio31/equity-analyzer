# ─── Variáveis de ambiente necessárias para load_av.py ───────────────────────
# Copie este arquivo como .env e preencha os valores.
# NUNCA commite o .env com valores reais.

# Chave da API Alpha Vantage (gratuita em alphavantage.co)
AV_KEY=SUA_CHAVE_AQUI

# URL de conexão PostgreSQL (disponível no dashboard do Render)
DATABASE_URL=postgresql://usuario:senha@host/banco
